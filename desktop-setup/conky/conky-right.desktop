[Desktop Entry]
Type=Application
Name=Conky System Info
Comment=Colors-style system stats on right side of desktop
Exec=bash -c 'for i in $(seq 1 30); do xdpyinfo -display :0 >/dev/null 2>&1 && break; sleep 1; done; sleep 5; DISPLAY=:0 /usr/bin/conky -c /home/osm/.config/conky/right.conf'
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
